   "metadata": {},
   "source": [
    "## 3. Prepare training data — strip system prompt\n",
    "\n",
    "We remove the system message from every training example so the model learns to be poetic **without** being told to."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "data-prep-base",
   "metadata": {},
   "outputs": [],
   "source": [
    "!python scripts/prepare_root_data.py \\\n",
    "  --source_dir /content/PET_QLORA_POET/data \\\n",
    "  --min_persona_strength medium"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "data-strip-sysprompt",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "\n",
    "def strip_system_prompt(src_path, dst_path):\n",
    "    stripped = 0\n",
    "    with open(src_path) as fin, open(dst_path, \"w\") as fout:\n",
    "        for line in fin:\n",
    "            ex = json.loads(line)\n",
    "            ex[\"messages\"] = [m for m in ex[\"messages\"] if m[\"role\"] != \"system\"]\n",
    "            fout.write(json.dumps(ex) + \"\\n\")\n",
    "            stripped += 1\n",
    "    print(f\"{dst_path}: {stripped} examples written (system prompt removed)\")\n",
    "\n",
    "strip_system_prompt(\n",
    "    \"data/generated/custom_train.jsonl\",\n",
    "    \"data/generated/custom_train_nsp.jsonl\"\n",
    ")\n",
    "strip_system_prompt(\n",
    "    \"data/generated/custom_val.jsonl\",\n",
    "    \"data/generated/custom_val_nsp.jsonl\"\n",
    ")"
   ]
  },
  {
